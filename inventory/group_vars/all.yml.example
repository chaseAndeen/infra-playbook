---
# --- AWS SSO / IAM Configuration ---
aws_profile: "YourSSOProfile"
aws_region: "us-east-1"

# --- User SSH Public Keys ---
admin_public_key: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/public_key', profile=aws_profile, region=aws_region) }}"
ansible_public_key: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/ansible_public_key', profile=aws_profile, region=aws_region) }}"
admin_password: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/admin_password', profile=aws_profile, region=aws_region) }}"
root_password: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/root_password', profile=aws_profile, region=aws_region) }}"

# --- Ansible service account ---
ansible_service_user: ansible

# --- SMTP Notifications ---
smtp_server: "email-smtp.us-east-1.amazonaws.com"
smtp_port: 587
smtp_from: "alerts@example.com"
smtp_to: "admin@example.com"
cloudflare_token: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/cloudflare/api_token', profile=aws_profile, region=aws_region) }}"
cloudflare_zone_id: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/cloudflare/zone_id', profile=aws_profile, region=aws_region) }}"

# --- SMTP (Common/Shared) ---
smtp_user: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/smtp/user', profile=aws_profile, region=aws_region) }}"
smtp_pass: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/smtp/pass', profile=aws_profile, region=aws_region) }}"

# --- SSL Cert ---
cert_email: admin@example.com

# --- Firewall Settings ---
mgmt_cidrs:
  - 192.168.x.x/24
  - 10.x.x.x/24

pve_network_cidr: "192.168.x.x/24"
svc_network_cidr: "192.168.x.x/24"

proxmox_firewall_enable_datacenter: true
proxmox_firewall_enable_node: true
proxmox_firewall_policy_in: DROP
proxmox_firewall_policy_out: ACCEPT
proxmox_firewall_policy_forward: ACCEPT
proxmox_firewall_ebtables: true

proxmox_manage_cluster_fw: true
proxmox_manage_host_fw: true

# --- OIDC Admin Users ---
# Email addresses (matching the username_claim) to grant Administrator in PVE.
# PVE user ID format: <email>@<oidc.realm_name>
pve_oidc_admins:
  - "admin@example.com"

pbs_oidc_admins:
  - "admin@example.com"

# --- Global Proxmox Settings ---
pve_bridge: "vmbr0"
pve_snippet_storage: "local"
pve_snippet_path: "/var/lib/vz/snippets"

proxmox_ssh_port: 2222
proxmox_gui_port: 8006
pbs_gui_port: 8007
proxmox_user: your-admin-username
proxmox_debian_release: trixie

# --- API User Passwords ---
terraform_tmp_pass: "{{ lookup('amazon.aws.ssm_parameter', '/infra/proxmox/terraform_tmp_pass', profile=aws_profile, region=aws_region) }}"
packer_api_password: "{{ lookup('amazon.aws.ssm_parameter', '/infra/proxmox/packer_api_password', profile=aws_profile, region=aws_region) }}"

# --- Services VM (svc-01) ---
svc_nfs_server: "nas.example.com"
svc_nfs_export: "/mnt/pool/container_data"
svc_traefik_domain: "traefik.apps.example.com"
svc_authentik_domain: "authentik.apps.example.com"
svc_unifi_domain: "unifi.apps.example.com"
svc_homepage_domain: "homepage.apps.example.com"
svc_truenas_host: "nas.example.com"     # IP or hostname of TrueNAS — used in homepage services tile
svc_opnsense_domain: "fw.example.com"   # FQDN of OPNsense — used in homepage services tile

# --- svc-01 UFW Rules ---
# Central registry for every inbound port opened on svc-01.
# Add an entry here when a new service needs non-standard access.
# proto: tcp | udp | any
svc_firewall_rules:
  - { port: "{{ proxmox_ssh_port }}", proto: tcp, src: "192.168.x.x/24", comment: "SSH" }
  - { port: "{{ proxmox_ssh_port }}", proto: tcp, src: "10.x.x.x/24",    comment: "SSH" }
  - { port: "80",  proto: tcp, src: "192.168.x.x/24", comment: "HTTP" }
  - { port: "80",  proto: tcp, src: "10.x.x.x/24",    comment: "HTTP" }
  - { port: "80",  proto: tcp, src: "192.168.x.x/24", comment: "HTTP (apps)" }
  - { port: "443", proto: tcp, src: "192.168.x.x/24", comment: "HTTPS" }
  - { port: "443", proto: tcp, src: "10.x.x.x/24",    comment: "HTTPS" }
  - { port: "443", proto: tcp, src: "192.168.x.x/24", comment: "HTTPS (apps)" }
  - { port: "8080", proto: tcp, src: "192.168.x.x/24", comment: "UniFi inform" }
  - { port: "3478", proto: udp, src: "192.168.x.x/24", comment: "UniFi STUN" }

# Authentik secrets
authentik_secret_key: "{{ lookup('amazon.aws.ssm_parameter', '/infra/svc/authentik/secret_key', profile=aws_profile, region=aws_region) }}"
authentik_postgres_password: "{{ lookup('amazon.aws.ssm_parameter', '/infra/svc/authentik/postgres_password', profile=aws_profile, region=aws_region) }}"
authentik_bootstrap_token: "{{ lookup('amazon.aws.ssm_parameter', '/infra/svc/authentik/bootstrap_token', profile=aws_profile, region=aws_region) }}"
# cloudflare_token is already defined above — reused for Traefik DNS-01 challenge

# UniFi secrets
unifi_mongo_root_password: "{{ lookup('amazon.aws.ssm_parameter', '/infra/svc/unifi/mongo_root_password', profile=aws_profile, region=aws_region) }}"
unifi_mongo_password: "{{ lookup('amazon.aws.ssm_parameter', '/infra/svc/unifi/mongo_password', profile=aws_profile, region=aws_region) }}"

# --- Proxy Services (Traefik + Authentik) ---
# Central registry for every service that gets a Traefik route and/or Authentik integration.
# See all.yml for full field documentation.
#
# auth options: none | forward_auth | oidc
# oidc.target options: pve | pbs | none
#
# Client secrets for oidc services are auto-generated by svc.yml and stored in SSM
# at /infra/svc/oidc/<name>/client_secret.
proxy_services:
  - name: pve
    label: "Proxmox VE"
    domain: "pve.apps.example.com"
    backend_url: "https://{{ hostvars['pve-node-01']['ansible_host'] }}:{{ proxmox_gui_port }}"
    backend_tls_skip_verify: true
    auth: oidc
    oidc:
      client_id: pve
      realm_name: authentik
      username_claim: email
      autocreate: true
      target: pve

  - name: pbs
    label: "Proxmox Backup Server"
    domain: "pbs.apps.example.com"
    backend_url: "https://{{ hostvars['pbs-01']['ansible_host'] }}:{{ pbs_gui_port }}"
    backend_tls_skip_verify: true
    auth: oidc
    oidc:
      client_id: pbs
      realm_name: authentik
      username_claim: email
      autocreate: true
      target: pbs

  - name: unifi
    label: "UniFi Network Application"
    domain: "unifi.apps.example.com"
    backend_url: "https://unifi-app:8443"
    backend_tls_skip_verify: true
    auth: none   # UniFi has native auth; forward_auth is optional but blocks mobile app access

  - name: homepage
    label: "Homepage"
    domain: "homepage.apps.example.com"
    backend_url: "http://homepage:3000"
    auth: none   # Public dashboard — add forward_auth if you want to gate it behind Authentik

  # Example: service with no native auth — use forward_auth to gate it behind Authentik
  # - name: my-dashboard
  #   label: "My Dashboard"
  #   domain: "dashboard.apps.example.com"
  #   backend_url: "http://192.168.x.x:3000"
  #   backend_tls_skip_verify: false
  #   auth: forward_auth

  # Example: plain proxy with no auth layer (publicly accessible)
  # - name: my-public-site
  #   label: "My Public Site"
  #   domain: "site.apps.example.com"
  #   backend_url: "http://192.168.x.x:8080"
  #   auth: none
