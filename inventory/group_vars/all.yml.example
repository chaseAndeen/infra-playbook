---
# --- AWS SSO / IAM Configuration ---
aws_profile: "YourSSOProfile"
aws_region: "us-east-1"

# --- User SSH Public Keys ---
admin_public_key: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/public_key', profile=aws_profile, region=aws_region) }}"
ansible_public_key: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/ansible_public_key', profile=aws_profile, region=aws_region) }}"
admin_password: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/admin_password', profile=aws_profile, region=aws_region) }}"
root_password: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/root_password', profile=aws_profile, region=aws_region) }}"

# --- Ansible service account ---
ansible_service_user: ansible

# --- Teleport ---
teleport_domain: "teleport.infra.example.com"
# Optional: issue a wildcard cert for this domain and add to Teleport https_keypairs.
# Required if any teleport_apps use a custom public_addr outside the teleport_domain.
teleport_wildcard_domain: ""
# Pin to match your Teleport server version (teleport version on the server).
# Update here and re-run --tags teleport_agent when upgrading Teleport.
teleport_agent_version: "17.0.0"

# --- Infrastructure hosts ---
# truenas_host is used as the Teleport app public_addr and Host header — point Unbound to the Teleport VM IP.
truenas_host: "truenas.infra.example.com"

# --- Teleport App Proxy ---
# Add an entry here for each web UI to expose through Teleport.
# Apps with public_addr are served at that hostname directly (requires Unbound → Teleport IP + wildcard cert).
teleport_apps:
  - name: proxmox-pve
    description: "Proxmox VE"
    uri: "https://192.168.x.x:8006"
    public_addr: "pve-01.{{ teleport_domain }}"
    insecure_skip_verify: true
    install_agent: true
    labels:
      env: infra
      type: hypervisor
  - name: proxmox-pbs
    description: "Proxmox Backup Server"
    uri: "https://192.168.x.x:8007"
    public_addr: "pbs-01.{{ teleport_domain }}"
    insecure_skip_verify: true
    install_agent: true
    labels:
      env: infra
      type: backup
  - name: truenas
    description: "TrueNAS"
    uri: "https://192.168.x.x"
    public_addr: "{{ truenas_host }}"
    insecure_skip_verify: true
    install_agent: false
    rewrite:
      headers:
        - "Host: {{ truenas_host }}"
      redirect:
        - "https://192.168.x.x"
    labels:
      env: infra
      type: storage

# --- SMTP Notifications ---
smtp_server: "email-smtp.us-east-1.amazonaws.com"
smtp_port: 587
smtp_from: "alerts@example.com"
smtp_to: "admin@example.com"
cloudflare_token: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/cloudflare/api_token', profile=aws_profile, region=aws_region) }}"
cloudflare_zone_id: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/cloudflare/zone_id', profile=aws_profile, region=aws_region) }}"

# --- SMTP (Common/Shared) ---
smtp_user: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/smtp/user', profile=aws_profile, region=aws_region) }}"
smtp_pass: "{{ lookup('amazon.aws.ssm_parameter', '/infra/common/smtp/pass', profile=aws_profile, region=aws_region) }}"

# --- SSL Cert (Teleport only) ---
cert_email: admin@example.com

# --- Firewall Settings ---
mgmt_cidrs:
  - 192.168.x.x/24
  - 10.x.x.x/24

pve_network_cidr: "192.168.x.x/24"

proxmox_firewall_enable_datacenter: true
proxmox_firewall_enable_node: true
proxmox_firewall_policy_in: DROP
proxmox_firewall_policy_out: ACCEPT
proxmox_firewall_policy_forward: ACCEPT
proxmox_firewall_ebtables: true

proxmox_manage_cluster_fw: true
proxmox_manage_host_fw: true

# --- Global Proxmox Settings ---
pve_bridge: "vmbr0"
pve_snippet_storage: "local"
pve_snippet_path: "/var/lib/vz/snippets"

proxmox_ssh_port: 2222
proxmox_gui_port: 8006
pbs_gui_port: 8007
proxmox_user: your-admin-username
proxmox_debian_release: trixie

# --- API User Passwords ---
terraform_tmp_pass: "{{ lookup('amazon.aws.ssm_parameter', '/infra/proxmox/terraform_tmp_pass', profile=aws_profile, region=aws_region) }}"
packer_api_password: "{{ lookup('amazon.aws.ssm_parameter', '/infra/proxmox/packer_api_password', profile=aws_profile, region=aws_region) }}"
