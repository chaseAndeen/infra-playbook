AUTHENTIK_SECRET_KEY={{ authentik_secret_key }}
AUTHENTIK_REDIS__HOST=redis
AUTHENTIK_POSTGRESQL__HOST=postgresql
AUTHENTIK_POSTGRESQL__USER=authentik
AUTHENTIK_POSTGRESQL__NAME=authentik
AUTHENTIK_POSTGRESQL__PASSWORD={{ authentik_postgres_password }}
POSTGRES_PASSWORD={{ authentik_postgres_password }}
POSTGRES_USER=authentik
POSTGRES_DB=authentik
AUTHENTIK_BOOTSTRAP_TOKEN={{ authentik_bootstrap_token }}
AUTHENTIK_EMAIL__HOST={{ smtp_server }}
AUTHENTIK_EMAIL__PORT={{ smtp_port }}
AUTHENTIK_EMAIL__USE_TLS=true
AUTHENTIK_EMAIL__USERNAME={{ smtp_user }}
AUTHENTIK_EMAIL__PASSWORD={{ smtp_pass }}
AUTHENTIK_EMAIL__FROM={{ smtp_from }}
# LDAP outpost token — populated by svc.yml after the ldap blueprint applies.
# Empty on first run; authentik-ldap is restarted once the token is stored.
LDAP_OUTPOST_TOKEN={{ lookup('amazon.aws.ssm_parameter', '/infra/svc/ldap/outpost_token', on_missing='warn', profile=aws_profile, region=aws_region) | default('', true) }}
