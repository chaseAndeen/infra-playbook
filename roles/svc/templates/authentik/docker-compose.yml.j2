services:
  postgresql:
    image: postgres:{{ svc_postgres_version }}
    container_name: authentik-postgres
    restart: unless-stopped
    user: "{{ svc_container_uid }}:{{ svc_container_gid }}"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -d $${POSTGRES_DB} -U $${POSTGRES_USER}"]
      start_period: 20s
      interval: 30s
      retries: 5
      timeout: 5s
    volumes:
      - {{ svc_nfs_mount }}/svc-01/postgres:/var/lib/postgresql/data
    env_file:
      - .env
    networks:
      - authentik-internal

  redis:
    image: redis:{{ svc_redis_version }}
    container_name: authentik-redis
    restart: unless-stopped
    user: "{{ svc_container_uid }}:{{ svc_container_gid }}"
    command: --save 60 1 --loglevel warning
    healthcheck:
      test: ["CMD-SHELL", "redis-cli ping | grep PONG"]
      start_period: 20s
      interval: 30s
      retries: 5
      timeout: 3s
    volumes:
      - {{ svc_nfs_mount }}/svc-01/redis:/data
    networks:
      - authentik-internal

  authentik-server:
    image: ghcr.io/goauthentik/server:{{ svc_authentik_version }}
    container_name: authentik-server
    restart: unless-stopped
    command: server
    user: "{{ svc_container_uid }}:{{ svc_container_gid }}"
    env_file:
      - .env
    volumes:
      - {{ svc_nfs_mount }}/svc-01/authentik:/media
    depends_on:
      postgresql:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - authentik-internal
      - proxy
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.authentik.rule=Host(`{{ svc_authentik_domain }}`)"
      - "traefik.http.routers.authentik.entrypoints=websecure"
      - "traefik.http.routers.authentik.tls=true"
      - "traefik.http.routers.authentik.tls.certresolver=cloudflare"
      - "traefik.http.routers.authentik.tls.domains[0].main=svc.kernelstack.dev"
      - "traefik.http.routers.authentik.tls.domains[0].sans=*.svc.kernelstack.dev"
      - "traefik.http.services.authentik.loadbalancer.server.port=9000"
      - "traefik.docker.network=proxy"

  authentik-worker:
    image: ghcr.io/goauthentik/server:{{ svc_authentik_version }}
    container_name: authentik-worker
    restart: unless-stopped
    command: worker
    user: "{{ svc_container_uid }}:{{ svc_container_gid }}"
    env_file:
      - .env
    volumes:
      - {{ svc_nfs_mount }}/svc-01/authentik:/media
    depends_on:
      postgresql:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - authentik-internal

networks:
  authentik-internal:
    driver: bridge
    internal: true
  proxy:
    external: true
