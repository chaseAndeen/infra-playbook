version: 1
metadata:
  name: proxy-services
  labels:
    blueprints.goauthentik.io/instantiate: "true"
entries:
{% for svc in proxy_services | selectattr('auth', 'in', ['oidc', 'forward_auth']) %}

  # =========================================================
  # {{ svc.label }}  (auth: {{ svc.auth }})
  # =========================================================
{% if svc.auth == 'oidc' %}
  - model: authentik_providers_oauth2.oauth2provider
    state: present
    identifiers:
      name: "{{ svc.name }}-oidc"
    attrs:
      name: "{{ svc.name }}-oidc"
      client_id: "{{ svc.oidc.client_id }}"
      client_secret: "{{ lookup('amazon.aws.ssm_parameter', '/infra/svc/oidc/' ~ svc.name ~ '/client_secret', profile=aws_profile, region=aws_region) }}"
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      # redirect_uris: Proxmox uses the backend IP for its internal OIDC callback but the
      # browser returns to the proxy domain. Adjust matching_mode to 'regex' and add a
      # path pattern if Authentik rejects the redirect during login.
      redirect_uris:
        - url: "https://{{ svc.domain }}"
          matching_mode: strict
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, authentik Self-signed Certificate]]
      property_mappings:
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, openid]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, email]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, profile]]
      sub_mode: user_email
      include_claims_in_id_token: true
      access_code_validity: "minutes=1"
      access_token_validity: "minutes=5"
      refresh_token_validity: "days=30"

  - model: authentik_core.application
    state: present
    identifiers:
      slug: "{{ svc.name }}"
    attrs:
      name: "{{ svc.label }}"
      slug: "{{ svc.name }}"
      provider: !Find [authentik_providers_oauth2.oauth2provider, [name, {{ svc.name }}-oidc]]
      meta_launch_url: "https://{{ svc.domain }}"
      meta_description: "{{ svc.label }} — OIDC SSO via Authentik"

{% elif svc.auth == 'forward_auth' %}
  - model: authentik_providers_proxy.proxyprovider
    state: present
    identifiers:
      name: "{{ svc.name }}-forward-auth"
    attrs:
      name: "{{ svc.name }}-forward-auth"
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      external_host: "https://{{ svc.domain }}"
      proxy_mode: forward_single
      access_token_validity: "hours=24"

  - model: authentik_core.application
    state: present
    identifiers:
      slug: "{{ svc.name }}"
    attrs:
      name: "{{ svc.label }}"
      slug: "{{ svc.name }}"
      provider: !Find [authentik_providers_proxy.proxyprovider, [name, {{ svc.name }}-forward-auth]]
      meta_launch_url: "https://{{ svc.domain }}"
      meta_description: "{{ svc.label }} — forward auth via Authentik"

{% endif %}
{% endfor %}
{% set forward_auth_services = proxy_services | selectattr('auth', 'equalto', 'forward_auth') | list %}
{% if forward_auth_services | length > 0 %}
  # Bind all forward_auth proxy providers to the embedded outpost.
  # This list is the full set — regenerated from proxy_services on every run.
  - model: authentik_outposts.outpost
    state: present
    identifiers:
      name: "authentik Embedded Outpost"
    attrs:
      name: "authentik Embedded Outpost"
      type: proxy
      providers:
{% for svc in forward_auth_services %}
        - !Find [authentik_providers_proxy.proxyprovider, [name, {{ svc.name }}-forward-auth]]
{% endfor %}
      config:
        authentik_host: "https://{{ svc_authentik_domain }}"
        authentik_host_insecure: false
        log_level: info
        object_naming_template: "ak-outpost-%(name)s"
{% endif %}
